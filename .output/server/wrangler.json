{
  "compatibility_date": "2024-09-19",
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "moodtracker",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "moodtracker_db",
      "database_name": "moodtracker-db",
      "database_id": "a70166ef-0d94-43f9-845c-48f46043196c"
    }
  ],
  "main": "index.mjs",
  "assets": {
    "binding": "ASSETS",
    "directory": "../public"
  },
  "no_bundle": true,
  "rules": [
    {
      "type": "ESModule",
      "globs": [
        "**/*.mjs",
        "**/*.js"
      ]
    }
  ]
}